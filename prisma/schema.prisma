generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id              String      @id @default(cuid())
  name            String
  category        String
  description     String
  price           Float
  imageUrl        String?
  sku             String?
  isInStock       Boolean     @default(true)
  highlights      Json?
  features        Json?
  packageIncludes Json?
  specifications  Json?
  attachments     Json?
  videoUrl        String?
  qna             Json?
  otherInfo       Json?
  brand           String?
  tags            Json?
  createdAt       DateTime    @default(now())
  orders          OrderItem[]
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  customerName   String
  phone          String
  address        String
  deliveryType   String
  paymentStatus  String      @default("PENDING")
  deliveryStatus String      @default("PROCESSING")
  createdAt      DateTime    @default(now())
  items          OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ProductRequest {
  id          String   @id @default(cuid())
  productName String
  category    String
  description String
  reason      String
  contact     String
  createdAt   DateTime @default(now())
}

model Profile {
  id        String            @id @default(cuid())
  userId    String            @unique
  fullName  String?
  phone     String?
  avatarUrl String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  addresses DeliveryAddress[]
}

model DeliveryAddress {
  id                   String   @id @default(cuid())
  profileId            String
  label                String
  fullName             String?
  phone                String?
  country              String   @default("India")
  address              String
  addressLine2         String?
  landmark             String?
  city                 String
  state                String?
  pinCode              String
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  profile              Profile  @relation(fields: [profileId], references: [id])
}
