generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  name        String
  category    String
  description String
  price       Float
  imageUrl    String?
  createdAt   DateTime    @default(now())
  orders      OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  phone         String
  address       String
  deliveryType  String
  paymentStatus String      @default("PENDING")
  createdAt     DateTime    @default(now())
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ProductRequest {
  id          String   @id @default(cuid())
  productName String
  category    String
  description String
  reason      String
  contact     String
  createdAt   DateTime @default(now())
}
